# DigitalWallet backend environment overrides
# Copy this file to .env and replace placeholder values.
# Only DB + RabbitMQ keys are included for now.

# Shared RabbitMQ
RabbitMQ__Host=localhost
RabbitMQ__Username=guest
RabbitMQ__Password=guest

# Optional global fallback if you want all services to share one DB connection (not recommended)
# ConnectionStrings__DefaultConnection=Server=localhost\\SQLEXPRESS;Database=DigitalWalletDb;Trusted_Connection=True;TrustServerCertificate=True;

# Per-service SQL Server connection strings (recommended)
AUTHSERVICE__ConnectionStrings__DefaultConnection=Server=localhost\\SQLEXPRESS;Database=AuthServiceDb;Trusted_Connection=True;TrustServerCertificate=True;
WALLETSERVICE__ConnectionStrings__DefaultConnection=Server=localhost\\SQLEXPRESS;Database=WalletServiceDb;Trusted_Connection=True;TrustServerCertificate=True;
REWARDSSERVICE__ConnectionStrings__DefaultConnection=Server=localhost\\SQLEXPRESS;Database=RewardsServiceDb;Trusted_Connection=True;TrustServerCertificate=True;
NOTIFICATIONSERVICE__ConnectionStrings__DefaultConnection=Server=localhost\\SQLEXPRESS;Database=NotificationServiceDb;Trusted_Connection=True;TrustServerCertificate=True;
ADMINSERVICE__ConnectionStrings__DefaultConnection=Server=localhost\\SQLEXPRESS;Database=AdminServiceDb;Trusted_Connection=True;TrustServerCertificate=True;
ADMINSERVICE__ConnectionStrings__RewardsConnection=Server=localhost\\SQLEXPRESS;Database=RewardsServiceDb;Trusted_Connection=True;TrustServerCertificate=True;
SUPPORTTICKETSERVICE__ConnectionStrings__DefaultConnection=Server=localhost\\SQLEXPRESS;Database=SupportTicketServiceDb;Trusted_Connection=True;TrustServerCertificate=True;
